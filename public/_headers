/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://assets.calendly.com; img-src 'self' data: https://www.google-analytics.com https://maps.googleapis.com https://maps.gstatic.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://saveyourweb-contact.pc-relange.workers.dev https://calendly.com; frame-src https://www.google.com https://calendly.com; font-src 'self'

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/logos/*
  Cache-Control: public, max-age=2592000

/*.webp
  Cache-Control: public, max-age=2592000

/favicon*
  Cache-Control: public, max-age=2592000

/og-image.jpg
  Cache-Control: public, max-age=2592000

/ressources/*
  Cache-Control: public, max-age=86400
