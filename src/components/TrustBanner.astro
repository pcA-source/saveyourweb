---
const clients = [
  { name: "NRJ Group", logo: "/logos/nrj.webp" },
  { name: "Edenred", logo: "/logos/edenred.webp" },
  { name: "IZAC", logo: "/logos/izac.webp" },
  { name: "L-Expert-Comptable", logo: "/logos/lexpert-comptable.webp" },
  { name: "Freelance Republik", logo: "/logos/freelance-republik.webp" },
  { name: "JD2M", logo: "/logos/jd2m.webp" },
  { name: "Replayce", logo: "/logos/replayce.webp" },
];
---

<section class="py-8 md:py-10 border-y border-primary/5 bg-black overflow-hidden relative">
  <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-black to-transparent z-10"></div>
  <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-black to-transparent z-10"></div>

  <!-- Title -->
  <div class="text-center mb-6">
    <span class="text-xs font-medium tracking-widest uppercase text-primary/30">Ils nous ont fait confiance</span>
  </div>
  
  <!-- Logo marquee -->
  <div class="flex items-center gap-16 md:gap-24 w-max animate-marquee">
    {[...clients, ...clients, ...clients, ...clients].map((client) => (
      <div class="flex items-center gap-3 whitespace-nowrap">
        <img 
          src={client.logo} 
          alt={client.name} 
          width="40" 
          height="40" 
          loading="lazy"
          decoding="async"
          class="w-10 h-10 object-contain opacity-40 grayscale hover:opacity-80 hover:grayscale-0 transition-all duration-300"
        />
        <span class="font-display text-lg md:text-xl font-bold tracking-widest text-primary/25 uppercase">
          {client.name}
        </span>
      </div>
    ))}
  </div>
</section>
