---
---

<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[9999] translate-y-full transition-transform duration-500 ease-out">
  <div class="bg-[rgba(15,15,15,0.95)] backdrop-blur-xl border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-5 md:py-6 flex flex-col md:flex-row items-start md:items-center gap-4 md:gap-8">
      <p class="text-sm text-white/70 leading-relaxed flex-1">
        Ce site utilise des cookies pour mesurer l'audience via Google Analytics. Aucune donnée n'est partagée avec des tiers.
        <a href="/politique-de-confidentialite/" class="text-accent-warm hover:underline ml-1">En savoir plus</a>
      </p>
      <div class="flex items-center gap-3 w-full md:w-auto flex-shrink-0">
        <button id="cookie-refuse" class="flex-1 md:flex-none px-5 py-2.5 rounded-full border border-white/20 text-sm font-medium text-white/70 hover:bg-white/10 transition-colors cursor-pointer">
          Refuser
        </button>
        <button id="cookie-accept" class="flex-1 md:flex-none px-5 py-2.5 rounded-full bg-accent-warm text-black text-sm font-medium hover:bg-accent-warm/90 transition-colors cursor-pointer">
          Accepter
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var STORAGE_KEY = 'syw_cookies_consent';
  var GA_ID = 'G-2C64SY9XCK';
  var SIX_MONTHS_MS = 180 * 24 * 60 * 60 * 1000;

  function getConsent() {
    try {
      var raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      var data = JSON.parse(raw);
      if (Date.now() - data.timestamp > SIX_MONTHS_MS) {
        localStorage.removeItem(STORAGE_KEY);
        return null;
      }
      return data.value;
    } catch(e) { return null; }
  }

  function setConsent(value) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ value: value, timestamp: Date.now() }));
  }

  function loadGA4() {
    if (document.querySelector('script[src*="googletagmanager.com/gtag/js?id=' + GA_ID + '"]')) return;
    var s = document.createElement('script');
    s.async = true;
    s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
    document.head.appendChild(s);
    window.dataLayer = window.dataLayer || [];
    function gtag(){window.dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GA_ID);
  }

  function hideBanner() {
    var banner = document.getElementById('cookie-banner');
    if (banner) banner.style.transform = 'translateY(100%)';
  }

  function showBanner() {
    var banner = document.getElementById('cookie-banner');
    if (banner) {
      banner.style.transform = 'translateY(0)';
    }
  }

  // Check existing consent
  var consent = getConsent();
  if (consent === 'accepted') {
    loadGA4();
  } else if (consent === null) {
    // No choice yet — show banner after small delay
    setTimeout(showBanner, 500);
  }
  // If 'refused', do nothing (no GA4, no banner)

  // Button handlers
  document.addEventListener('DOMContentLoaded', function() {
    var acceptBtn = document.getElementById('cookie-accept');
    var refuseBtn = document.getElementById('cookie-refuse');

    if (acceptBtn) {
      acceptBtn.addEventListener('click', function() {
        setConsent('accepted');
        loadGA4();
        hideBanner();
      });
    }

    if (refuseBtn) {
      refuseBtn.addEventListener('click', function() {
        setConsent('refused');
        hideBanner();
      });
    }
  });

  // Expose reset function for "Gérer les cookies" link
  window.resetCookieConsent = function() {
    localStorage.removeItem(STORAGE_KEY);
    showBanner();
  };
})();
</script>
