---
const stats = [
  { value: "40%", label: "des recherches Google affichent une AI Overview" },
  { value: "100M+", label: "requêtes/mois sur Perplexity seul" },
  { value: "65%", label: "des utilisateurs ChatGPT l'utilisent pour rechercher" },
];

const services = [
  {
    title: "Audit de visibilité IA",
    description: "Analysez votre présence dans les réponses de ChatGPT, Perplexity, Gemini et les AI Overviews de Google.",
    icon: "eye",
  },
  {
    title: "Contenu optimisé pour les LLMs",
    description: "Structurez vos contenus pour être cités et recommandés par les modèles de langage.",
    icon: "file",
  },
  {
    title: "Stratégie d'autorité IA",
    description: "Construisez les signaux de confiance que les IA utilisent pour sélectionner leurs sources.",
    icon: "shield",
  },
  {
    title: "Schema.org IA-ready",
    description: "Implémentez les données structurées qui facilitent la compréhension par les moteurs IA.",
    icon: "code",
  },
];
---

<section class="py-24 lg:py-32 bg-black relative overflow-hidden">
  <div class="absolute top-1/2 left-0 w-[400px] h-[400px] bg-accent-warm/5 rounded-full blur-[120px] pointer-events-none -translate-y-1/2"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 rounded-full bg-accent-warm/10 border border-accent-warm/20 px-4 py-1.5 text-sm font-medium text-accent-warm mb-8">
      <span>🤖</span>
      <span>Nouveau</span>
    </div>

    <div class="flex items-center gap-4 mb-8">
      <div class="h-px w-6 bg-accent-warm"></div>
      <span class="text-sm font-medium tracking-wide uppercase text-accent-warm">Generative Engine Optimization</span>
    </div>

    <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight mb-6 max-w-4xl">
      Le SEO ne suffit plus.<br />
      <span class="text-primary/50">Le GEO l'amplifie.</span>
    </h2>

    <p class="text-lg text-primary/60 mb-16 max-w-2xl">
      Vos futurs clients ne cherchent plus seulement sur Google. Ils demandent à ChatGPT, Perplexity, Gemini. Êtes-vous visible dans leurs réponses ?
    </p>

    <!-- Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
      {stats.map((stat) => (
        <div class="border-t border-primary/10 pt-8 relative group">
          <div class="absolute top-0 left-0 w-0 h-px bg-accent-warm transition-all duration-700 group-hover:w-full"></div>
          <h3 class="font-display text-5xl md:text-6xl font-medium tracking-tighter text-primary mb-4">
            {stat.value}
          </h3>
          <p class="text-primary/60 leading-relaxed">{stat.label}</p>
        </div>
      ))}
    </div>

    <!-- Services -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {services.map((s) => (
        <div class="bg-primary/5 border border-primary/10 rounded-2xl p-8 hover:bg-primary/[0.07] transition-colors group">
          <div class="w-12 h-12 rounded-xl bg-accent-warm/10 border border-accent-warm/20 flex items-center justify-center mb-6">
            {s.icon === "eye" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(25 100% 50%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            )}
            {s.icon === "file" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(25 100% 50%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            )}
            {s.icon === "shield" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(25 100% 50%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            )}
            {s.icon === "code" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(25 100% 50%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            )}
          </div>
          <h3 class="font-display text-xl font-medium mb-3">{s.title}</h3>
          <p class="text-primary/60 leading-relaxed">{s.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
