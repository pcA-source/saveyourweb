---
const faqs = [
  {
    question: "En combien de temps vais-je voir des résultats ?",
    answer: "Des quick wins sont visibles dès les premières semaines (corrections techniques, optimisations on-page). Les vrais résultats SEO apparaissent entre 3 et 6 mois. Pour des résultats solides et durables, comptez 6 à 12 mois. Le SEO est un investissement à long terme — c'est ce qui en fait la force.",
  },
  {
    question: "Pouvez-vous garantir des résultats ?",
    answer: "Non, et méfiez-vous de quiconque le prétend. Personne ne contrôle l'algorithme de Google. En revanche, notre méthodologie éprouvée, nos 10 ans d'expérience et un résultat moyen de +40% de trafic qualifié parlent d'eux-mêmes.",
  },
  {
    question: "Quelle est la différence avec une agence ?",
    answer: "Un interlocuteur unique et senior — pas de junior qui apprend sur votre compte. Une réactivité incomparable, une connaissance profonde de votre projet, et une implication personnelle dans vos résultats.",
  },
  {
    question: "Combien ça coûte ?",
    answer: "Chaque projet est unique : un site vitrine de 10 pages et un e-commerce de 100 000 pages avec des centaines de facettes, ce n'est pas le même travail. C'est pourquoi nous établissons un devis sur-mesure après un audit gratuit de votre situation. Pas de grille tarifaire générique — un budget adapté à vos objectifs et à la complexité réelle de votre site.",
  },
  {
    question: "Vous travaillez aussi en SEA ?",
    answer: "Oui, nous gérons des campagnes Google Ads et Meta Ads. L'idéal est de combiner SEO et SEA pour maximiser le ROI global : le SEA génère des résultats immédiats pendant que le SEO construit une croissance durable.",
  },
];
---

<section class="py-24 lg:py-32 bg-black relative">
  <div class="max-w-4xl mx-auto px-7 md:px-12 lg:px-20">
    <div class="flex items-center gap-4 mb-8">
      <div class="h-px w-6 bg-accent-warm"></div>
      <span class="text-sm font-medium tracking-wide uppercase text-accent-warm">FAQ</span>
    </div>

    <h2 class="reveal font-display text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight mb-16 max-w-3xl">
      Questions fréquentes
    </h2>

    <div class="space-y-4" id="faq-list">
      {faqs.map((faq, i) => (
        <div class="faq-item border border-primary/10 rounded-2xl overflow-hidden" data-faq-index={i}>
          <button
            class="faq-trigger w-full flex items-center justify-between gap-4 p-6 md:p-8 text-left cursor-pointer hover:bg-primary/5 transition-colors"
            aria-expanded="false"
          >
            <span class="font-display text-lg md:text-xl font-medium pr-4">{faq.question}</span>
            <svg
              class="faq-icon flex-shrink-0 w-6 h-6 text-accent-warm transition-transform duration-300"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="12" y1="5" x2="12" y2="19" />
              <line x1="5" y1="12" x2="19" y2="12" />
            </svg>
          </button>
          <div class="faq-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
            <div class="px-6 md:px-8 pb-6 md:pb-8">
              <p class="text-primary/70 leading-relaxed text-lg">{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const content = item.querySelector('.faq-content') as HTMLElement;
      const icon = item.querySelector('.faq-icon') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      // Close all others
      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          const otherContent = other.querySelector('.faq-content') as HTMLElement;
          const otherIcon = other.querySelector('.faq-icon') as HTMLElement;
          const otherBtn = other.querySelector('.faq-trigger') as HTMLElement;
          otherContent.style.maxHeight = '0';
          otherIcon.style.transform = 'rotate(0deg)';
          otherBtn.setAttribute('aria-expanded', 'false');
        }
      });

      if (isOpen) {
        content.style.maxHeight = '0';
        icon.style.transform = 'rotate(0deg)';
        btn.setAttribute('aria-expanded', 'false');
      } else {
        content.style.maxHeight = content.scrollHeight + 'px';
        icon.style.transform = 'rotate(45deg)';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
