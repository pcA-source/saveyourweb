---
const metrics = [
  { value: "+200%", label: "Croissance moyenne du trafic organique sur 12 mois*" },
  { value: "Top 3", label: "Positions atteintes sur les requêtes stratégiques ciblées*" },
  { value: "95%", label: "De nos clients renouvellent leur accompagnement" },
];
---

<section id="resultats" class="py-24 lg:py-32 bg-black relative overflow-hidden">
  <!-- Background glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-accent-warm/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20">
      <div>
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px w-6 bg-accent-warm"></div>
          <span class="text-sm font-medium tracking-wide uppercase text-accent-warm">Nos Résultats</span>
        </div>
        <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight max-w-2xl">
          Nous ne vendons pas du vent.<br />
          <span class="text-primary/50">Nous vendons du ROI.</span>
        </h2>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {metrics.map((metric) => (
        <div class="border-t border-primary/10 pt-8 relative group">
          <div class="absolute top-0 left-0 w-0 h-px bg-accent-warm transition-all duration-700 group-hover:w-full"></div>
          <h3 class="font-display text-6xl md:text-7xl lg:text-8xl font-medium tracking-tighter text-primary mb-6">
            {metric.value}
          </h3>
          <p class="text-lg text-primary/60 leading-relaxed max-w-xs">
            {metric.label}
          </p>
        </div>
      ))}
    </div>

    <!-- Chart graphic -->
    <div class="mt-24 relative h-64 md:h-96 w-full rounded-3xl border border-primary/10 bg-primary/5 overflow-hidden flex items-end p-8">
      <div class="absolute inset-0 bg-gradient-to-t from-accent-warm/10 to-transparent opacity-50"></div>
      
      <svg class="absolute inset-0 w-full h-full" preserveAspectRatio="none" viewBox="0 0 1000 300">
        <defs>
          <linearGradient id="chart-gradient" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="hsl(25 100% 50%)" stop-opacity="0.3" />
            <stop offset="100%" stop-color="hsl(25 100% 50%)" stop-opacity="0" />
          </linearGradient>
        </defs>
        <path 
          d="M0,300 L0,250 C100,240 200,280 300,200 C400,120 500,180 600,100 C700,20 800,80 900,40 L1000,10 L1000,300 Z" 
          fill="url(#chart-gradient)" 
        />
        <path 
          d="M0,250 C100,240 200,280 300,200 C400,120 500,180 600,100 C700,20 800,80 900,40 L1000,10" 
          fill="none" 
          stroke="hsl(25 100% 50%)" 
          stroke-width="4"
        />
      </svg>
      
      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 rounded-full bg-black/50 backdrop-blur-md border border-primary/10 px-4 py-2 text-sm font-medium">
          <div class="w-2 h-2 rounded-full bg-accent-warm animate-pulse"></div>
          Croissance Client Type
        </div>
      </div>
    </div>

    <p class="mt-6 text-xs text-primary/30 italic">
      * Résultats moyens constatés chez nos clients. Les performances individuelles peuvent varier selon le secteur, la concurrence et l'état initial du site.
    </p>
  </div>
</section>
