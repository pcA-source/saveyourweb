---
---

<section class="relative min-h-screen flex items-center pt-24 overflow-hidden">
  <!-- Rich background -->
  <div class="absolute inset-0 z-0">
    <!-- Base gradient -->
    <div class="absolute inset-0 bg-gradient-to-br from-black via-black to-accent-warm/10"></div>
    
    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
    
    <!-- Glow orbs -->
    <div class="absolute top-[10%] right-[10%] w-[500px] h-[500px] bg-accent-warm/8 rounded-full blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-[20%] left-[5%] w-[300px] h-[300px] bg-accent-warm/5 rounded-full blur-[100px] animate-pulse-slow" style="animation-delay: 2s;"></div>
    <div class="absolute top-[50%] right-[30%] w-[200px] h-[200px] bg-primary/5 rounded-full blur-[80px]"></div>
    
    <!-- Radial gradients -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_hsl(25_100%_50%/0.12)_0%,_transparent_50%)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,_hsl(25_100%_50%/0.06)_0%,_transparent_40%)]"></div>
    
    <!-- Top/bottom vignette -->
    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/60"></div>
    
    <!-- Floating particles SVG -->
    <svg class="absolute inset-0 w-full h-full opacity-20" xmlns="http://www.w3.org/2000/svg">
      <circle cx="15%" cy="20%" r="1.5" fill="hsl(25 100% 50%)" class="animate-float">
        <animate attributeName="cy" values="20%;18%;20%" dur="4s" repeatCount="indefinite"/>
      </circle>
      <circle cx="80%" cy="30%" r="1" fill="hsl(25 100% 50%)" class="animate-float">
        <animate attributeName="cy" values="30%;27%;30%" dur="5s" repeatCount="indefinite"/>
      </circle>
      <circle cx="60%" cy="70%" r="2" fill="hsl(25 100% 50%/0.6)">
        <animate attributeName="cy" values="70%;67%;70%" dur="6s" repeatCount="indefinite"/>
      </circle>
      <circle cx="25%" cy="60%" r="1" fill="hsl(0 0% 95%/0.4)">
        <animate attributeName="cy" values="60%;57%;60%" dur="3.5s" repeatCount="indefinite"/>
      </circle>
      <circle cx="90%" cy="80%" r="1.5" fill="hsl(25 100% 50%/0.4)">
        <animate attributeName="cy" values="80%;77%;80%" dur="4.5s" repeatCount="indefinite"/>
      </circle>
      <circle cx="45%" cy="15%" r="1" fill="hsl(0 0% 95%/0.3)">
        <animate attributeName="cy" values="15%;12%;15%" dur="5.5s" repeatCount="indefinite"/>
      </circle>
      <!-- Connecting lines -->
      <line x1="15%" y1="20%" x2="45%" y2="15%" stroke="hsl(25 100% 50%/0.06)" stroke-width="0.5"/>
      <line x1="80%" y1="30%" x2="60%" y2="70%" stroke="hsl(25 100% 50%/0.04)" stroke-width="0.5"/>
      <line x1="60%" y1="70%" x2="90%" y2="80%" stroke="hsl(25 100% 50%/0.04)" stroke-width="0.5"/>
    </svg>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
    <div class="max-w-4xl">
      <div class="animate-fade-in-up inline-flex items-center gap-2 rounded-full border border-primary/20 bg-black/50 backdrop-blur-md px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-primary mb-8">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
        Agence SEO & SEA
      </div>

      <h1 class="animate-fade-in-up-delay-1 font-display text-5xl md:text-6xl lg:text-[78px] leading-[1.05] font-medium tracking-tight text-primary mb-8">
        Dominez Google.<br />
        <span class="text-primary/60">Maximisez votre ROI.</span>
      </h1>
      
      <p class="animate-fade-in-up-delay-2 text-xl text-primary/70 mb-12 max-w-2xl leading-relaxed">
        Référencement naturel et campagnes Google Ads : nous combinons SEO et SEA pour placer votre entreprise devant les clients qui comptent. Plus de visibilité, plus de conversions, plus de croissance.
      </p>

      <div class="animate-fade-in-up-delay-3 flex flex-wrap items-center gap-6">
        <a href="#contact" class="group flex items-center gap-4 rounded-full pl-6 pr-4 py-3 bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors">
          Demander un Audit Gratuit
          <span class="w-8 h-8 rounded-full bg-primary-foreground flex items-center justify-center text-primary group-hover:scale-95 transition-transform">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </span>
        </a>
        <span class="text-sm text-primary/50 font-medium">
          Accompagnement personnalisé · Résultats mesurables
        </span>
      </div>
    </div>
  </div>
</section>
