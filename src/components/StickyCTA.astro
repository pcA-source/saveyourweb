<div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-50 md:hidden translate-y-full transition-transform duration-300">
  <div class="bg-black/90 backdrop-blur-xl border-t border-primary/10 px-4 py-3">
    <a
      href="#"
      onclick="Calendly.initPopupWidget({url:'https://calendly.com/rdv-seo-save-your-web/30min'});return false;"
      class="flex items-center justify-center gap-2 w-full bg-accent-warm text-black font-medium px-6 py-3.5 rounded-full text-base hover:bg-accent-warm/90 transition-colors"
    >
      Audit gratuit
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
</div>

<script>
  const stickyCta = document.getElementById('sticky-cta') as HTMLElement;
  let shown = false;

  window.addEventListener('scroll', () => {
    const shouldShow = window.scrollY > 500;
    if (shouldShow && !shown) {
      stickyCta.style.transform = 'translateY(0)';
      shown = true;
    } else if (!shouldShow && shown) {
      stickyCta.style.transform = 'translateY(100%)';
      shown = false;
    }
  }, { passive: true });
</script>
