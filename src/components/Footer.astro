---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black py-16 border-t border-primary/10">
  <div class="max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <a href="/" class="font-display font-bold text-xl tracking-tight text-primary">
          Save Your Web<span class="text-accent-warm">.</span>
        </a>
        <p class="mt-4 text-sm text-primary/50 leading-relaxed">
          Agence SEO & SEA spécialisée en référencement naturel et Google Ads pour PME, e-commerce et startups.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="font-display font-medium text-sm uppercase tracking-widest text-primary/60 mb-4">Services</h4>
        <ul class="space-y-3">
          <li><a href="/services/seo/" class="text-sm text-primary/50 hover:text-primary transition-colors">Référencement Naturel (SEO)</a></li>
          <li><a href="/services/sea/" class="text-sm text-primary/50 hover:text-primary transition-colors">Google Ads & SEA</a></li>
        </ul>
      </div>

      <!-- Ressources -->
      <div>
        <h4 class="font-display font-medium text-sm uppercase tracking-widest text-primary/60 mb-4">Ressources</h4>
        <ul class="space-y-3">
          <li><a href="/etudes-de-cas/" class="text-sm text-primary/50 hover:text-primary transition-colors">Études de cas</a></li>
          <li><a href="/blog/" class="text-sm text-primary/50 hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/a-propos/" class="text-sm text-primary/50 hover:text-primary transition-colors">À Propos</a></li>
          <li><a href="/#contact" class="text-sm text-primary/50 hover:text-primary transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Légal -->
      <div>
        <h4 class="font-display font-medium text-sm uppercase tracking-widest text-primary/60 mb-4">Légal</h4>
        <ul class="space-y-3">
          <li><a href="/mentions-legales" class="text-sm text-primary/50 hover:text-primary transition-colors">Mentions légales</a></li>
          <li><a href="/politique-de-confidentialite" class="text-sm text-primary/50 hover:text-primary transition-colors">Confidentialité</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-primary/10 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-sm text-primary/40">
        © {currentYear} Save Your Web. Tous droits réservés.
      </div>
      <a href="mailto:contact@saveyourweb.fr" class="text-sm text-primary/50 hover:text-accent-warm transition-colors">
        contact@saveyourweb.fr
      </a>
    </div>
  </div>
</footer>
