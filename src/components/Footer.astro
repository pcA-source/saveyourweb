---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black py-12 border-t border-primary/10">
  <div class="max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <a href="/" class="font-display font-bold text-xl tracking-tight text-primary">
        Save Your Web<span class="text-accent-warm">.</span>
      </a>
      
      <div class="flex items-center gap-6 text-sm text-primary/50">
        <a href="/mentions-legales" class="hover:text-primary transition-colors">Mentions légales</a>
        <a href="/politique-de-confidentialite" class="hover:text-primary transition-colors">Confidentialité</a>
        <a href="mailto:contact@saveyourweb.fr" class="hover:text-primary transition-colors">contact@saveyourweb.fr</a>
      </div>
      
      <div class="text-sm text-primary/50">
        © {currentYear} Save Your Web. Tous droits réservés.
      </div>
    </div>
  </div>
</footer>
