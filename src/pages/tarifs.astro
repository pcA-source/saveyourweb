---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';

const plans = [
  {
    name: "Audit SEO",
    price: "490€ HT",
    type: "One-shot",
    popular: false,
    features: [
      "Audit technique complet",
      "Analyse sémantique",
      "Audit backlinks",
      "Rapport détaillé + recommandations",
      "Call de restitution 1h",
    ],
    cta: "Demander un audit",
  },
  {
    name: "Accompagnement SEO",
    price: "990€ HT/mois",
    type: "Mensuel",
    popular: true,
    features: [
      "Stratégie SEO personnalisée",
      "Optimisations techniques mensuelles",
      "Création de contenu (2-4 articles/mois)",
      "Netlinking qualitatif",
      "Reporting mensuel détaillé",
      "Call mensuel de suivi",
    ],
    cta: "Lancer mon SEO",
  },
  {
    name: "Google Ads",
    price: "590€ HT/mois",
    type: "Mensuel (hors budget pub)",
    popular: false,
    features: [
      "Audit et restructuration des campagnes",
      "Création d'annonces optimisées",
      "Ciblage et enchères",
      "Suivi des conversions",
      "Reporting hebdomadaire",
      "Optimisation continue",
    ],
    cta: "Lancer mes campagnes",
  },
];

const faqs = [
  {
    question: "Pourquoi 'à partir de' ?",
    answer: "Chaque projet est unique. Le tarif dépend de la taille de votre site, de votre marché, de la concurrence et de vos objectifs. Nous établissons un devis sur-mesure après un audit gratuit de votre situation."
  },
  {
    question: "Y a-t-il un engagement ?",
    answer: "Non. Pas d'engagement de durée. Notre collaboration est résiliable avec 30 jours de préavis. Nous pensons que la qualité de nos résultats est le meilleur engagement."
  },
  {
    question: "Le budget publicitaire est-il inclus ?",
    answer: "Non, nos honoraires couvrent la gestion et l'optimisation de vos campagnes. Le budget média (dépenses publicitaires Google Ads) est séparé et reste sous votre contrôle."
  },
  {
    question: "Comment se passe le démarrage ?",
    answer: "C'est simple : audit initial gratuit de votre situation, proposition commerciale détaillée, validation de votre côté, puis Go. Nous pouvons démarrer sous 48h après validation."
  },
];
---

<Layout 
  title="Tarifs SEO & Google Ads — Save Your Web"
  description="Découvrez nos tarifs SEO et Google Ads. À partir de 490€ pour un audit complet. Accompagnement mensuel dès 990€/mois."
>
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-16 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-black via-black to-accent-warm/10"></div>
        <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
        <div class="absolute top-[30%] right-[10%] w-[500px] h-[500px] bg-accent-warm/8 rounded-full blur-[120px] animate-pulse-slow"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-7 md:px-12 lg:px-20 text-center">
        <div class="reveal inline-flex items-center gap-2 rounded-full border border-primary/20 bg-black/50 backdrop-blur-md px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-primary mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm"><line x1="12" x2="12" y1="2" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Tarifs
        </div>
        <h1 class="reveal font-display text-4xl md:text-5xl lg:text-[72px] leading-[1.05] font-medium tracking-tight text-primary mb-6">
          Des offres claires,<br />
          <span class="text-primary/60">sans surprise</span>
        </h1>
        <p class="reveal text-xl text-primary/70 max-w-2xl mx-auto leading-relaxed">
          Des tarifs transparents adaptés à la taille de votre projet. Chaque euro investi est orienté résultats.
        </p>
      </div>
    </section>

    <!-- Pricing cards -->
    <section class="py-16 lg:py-24 bg-black relative">
      <div class="max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {plans.map((plan) => (
            <div class={`reveal relative rounded-2xl p-8 md:p-10 flex flex-col ${plan.popular ? 'border-2 border-accent-warm bg-accent-warm/5' : 'border border-primary/10 bg-primary/5'}`}>
              {plan.popular && (
                <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                  <span class="inline-flex items-center gap-1 rounded-full bg-accent-warm px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-white">
                    ⭐ Populaire
                  </span>
                </div>
              )}

              <div class="mb-8">
                <h3 class="font-display text-2xl font-medium mb-2">{plan.name}</h3>
                <p class="text-sm text-primary/50 mb-6">{plan.type}</p>
                <div class="flex items-baseline gap-1">
                  <span class="text-sm text-primary/50">À partir de</span>
                </div>
                <div class="font-display text-4xl md:text-5xl font-medium tracking-tight mt-1">
                  {plan.price}
                </div>
              </div>

              <ul class="space-y-4 mb-10 flex-1">
                {plan.features.map((f) => (
                  <li class="flex items-start gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm flex-shrink-0 mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span class="text-primary/70">{f}</span>
                  </li>
                ))}
              </ul>

              <a 
                href="#" 
                onclick="Calendly.initPopupWidget({url:'https://calendly.com/rdv-seo-save-your-web/30min'});return false;" 
                class={`cta-glow group flex items-center justify-center gap-3 rounded-full py-4 font-medium text-lg transition-colors ${plan.popular ? 'bg-accent-warm text-white hover:bg-accent-warm/90' : 'bg-primary text-primary-foreground hover:bg-primary/90'}`}
              >
                {plan.cta}
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ Tarifs -->
    <section class="py-24 lg:py-32 bg-black relative">
      <div class="max-w-4xl mx-auto px-7 md:px-12 lg:px-20">
        <div class="flex items-center gap-4 mb-8">
          <div class="h-px w-6 bg-accent-warm"></div>
          <span class="text-sm font-medium tracking-wide uppercase text-accent-warm">FAQ Tarifs</span>
        </div>
        <h2 class="reveal font-display text-4xl md:text-5xl font-medium tracking-tight mb-16">
          Questions fréquentes
        </h2>

        <div class="space-y-4" id="faq-list-tarifs">
          {faqs.map((faq, i) => (
            <div class="faq-item border border-primary/10 rounded-2xl overflow-hidden" data-faq-index={i}>
              <button class="faq-trigger w-full flex items-center justify-between gap-4 p-6 md:p-8 text-left cursor-pointer hover:bg-primary/5 transition-colors" aria-expanded="false">
                <span class="font-display text-lg md:text-xl font-medium pr-4">{faq.question}</span>
                <svg class="faq-icon flex-shrink-0 w-6 h-6 text-accent-warm transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              </button>
              <div class="faq-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
                <div class="px-6 md:px-8 pb-6 md:pb-8">
                  <p class="text-primary/70 leading-relaxed text-lg">{faq.answer}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 lg:py-32 bg-black">
      <div class="max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
        <div class="relative rounded-[2rem] overflow-hidden border border-primary/10">
          <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-br from-accent-warm/15 via-black to-accent-warm/5"></div>
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_hsl(25_100%_50%/0.1)_0%,_transparent_50%)]"></div>
            <div class="absolute inset-0 bg-black/40"></div>
          </div>
          <div class="relative z-10 p-8 md:p-16 lg:p-20 text-center">
            <h2 class="reveal font-display text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight mb-6">
              Un projet en tête ?
            </h2>
            <p class="reveal text-xl text-primary/70 mb-10 max-w-2xl mx-auto">
              Demandez votre audit gratuit — nous analysons votre situation et vous proposons une offre sur-mesure.
            </p>
            <a href="#" onclick="Calendly.initPopupWidget({url:'https://calendly.com/rdv-seo-save-your-web/30min'});return false;" class="reveal cta-glow inline-flex items-center gap-4 rounded-full pl-8 pr-4 py-4 bg-primary text-primary-foreground font-medium text-lg hover:bg-primary/90 transition-colors">
              Réserver un appel gratuit
              <span class="w-10 h-10 rounded-full bg-primary-foreground text-primary flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <StickyCTA />
</Layout>

<script>
  document.querySelectorAll('.faq-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const content = item.querySelector('.faq-content') as HTMLElement;
      const icon = item.querySelector('.faq-icon') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';
      document.querySelectorAll('.faq-item').forEach((other) => {
        if (other !== item) {
          const oc = other.querySelector('.faq-content') as HTMLElement;
          const oi = other.querySelector('.faq-icon') as HTMLElement;
          const ob = other.querySelector('.faq-trigger') as HTMLElement;
          oc.style.maxHeight = '0';
          oi.style.transform = 'rotate(0deg)';
          ob.setAttribute('aria-expanded', 'false');
        }
      });
      if (isOpen) {
        content.style.maxHeight = '0';
        icon.style.transform = 'rotate(0deg)';
        btn.setAttribute('aria-expanded', 'false');
      } else {
        content.style.maxHeight = content.scrollHeight + 'px';
        icon.style.transform = 'rotate(45deg)';
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
