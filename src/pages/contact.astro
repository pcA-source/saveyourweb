---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';
---

<Layout 
  title="Contact — Save Your Web"
  description="Contactez Save Your Web pour discuter de votre projet SEO ou Google Ads. Audit gratuit en 24h."
>
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-20 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-black via-black to-accent-warm/10"></div>
        <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
        <div class="absolute top-[20%] right-[15%] w-[400px] h-[400px] bg-accent-warm/8 rounded-full blur-[120px] animate-pulse-slow"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
          <!-- Left column: Form -->
          <div>
            <div class="reveal inline-flex items-center gap-2 rounded-full border border-primary/20 bg-black/50 backdrop-blur-md px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-primary mb-8">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              Contact
            </div>

            <h1 class="reveal font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] font-medium tracking-tight text-primary mb-6">
              Parlons de<br />
              <span class="text-primary/60">votre projet</span>
            </h1>

            <p class="reveal text-lg text-primary/70 mb-10 max-w-lg leading-relaxed">
              Remplissez le formulaire ci-dessous ou réservez directement un créneau. Nous vous répondons sous 24h.
            </p>

            <!-- Success -->
            <div id="form-success" class="hidden bg-accent-warm/10 border border-accent-warm/30 rounded-2xl p-8 text-center mb-8">
              <div class="text-4xl mb-4">✅</div>
              <h3 class="font-display text-2xl font-medium mb-2">Message envoyé !</h3>
              <p class="text-primary/70">Nous reviendrons vers vous très rapidement.</p>
            </div>
            <div id="form-error" class="hidden bg-red-500/10 border border-red-500/30 rounded-2xl p-6 mb-6 text-red-400"></div>

            <!-- Form -->
            <form id="contact-form" data-form="contact" class="reveal grid grid-cols-1 md:grid-cols-2 gap-6" method="POST">
              <div class="flex flex-col gap-2">
                <label for="name" class="text-sm font-medium text-primary/60 uppercase tracking-wider">Nom</label>
                <input 
                  type="text" id="name" name="name" required
                  class="bg-black/50 border border-primary/20 rounded-xl px-4 py-3 text-primary placeholder:text-primary/30 focus:outline-none focus:border-accent-warm/50 transition-colors backdrop-blur-md"
                  placeholder="Votre nom"
                />
              </div>
              
              <div class="flex flex-col gap-2">
                <label for="email" class="text-sm font-medium text-primary/60 uppercase tracking-wider">Email</label>
                <input 
                  type="email" id="email" name="email" required
                  class="bg-black/50 border border-primary/20 rounded-xl px-4 py-3 text-primary placeholder:text-primary/30 focus:outline-none focus:border-accent-warm/50 transition-colors backdrop-blur-md"
                  placeholder="votre@email.com"
                />
              </div>
              
              <div class="flex flex-col gap-2 md:col-span-2">
                <label for="website" class="text-sm font-medium text-primary/60 uppercase tracking-wider">Site web</label>
                <input 
                  type="url" id="website" name="website"
                  class="bg-black/50 border border-primary/20 rounded-xl px-4 py-3 text-primary placeholder:text-primary/30 focus:outline-none focus:border-accent-warm/50 transition-colors backdrop-blur-md"
                  placeholder="https://votresite.fr"
                />
              </div>
              
              <div class="flex flex-col gap-2 md:col-span-2">
                <label for="message" class="text-sm font-medium text-primary/60 uppercase tracking-wider">Message</label>
                <textarea 
                  id="message" name="message" rows="5"
                  class="bg-black/50 border border-primary/20 rounded-xl px-4 py-3 text-primary placeholder:text-primary/30 focus:outline-none focus:border-accent-warm/50 transition-colors backdrop-blur-md resize-none"
                  placeholder="Parlez-nous de votre projet..."
                ></textarea>
              </div>
              
              <div class="md:col-span-2">
                <button 
                  type="submit" 
                  class="cta-glow group flex items-center gap-4 rounded-full pl-8 pr-3 py-3 bg-primary text-primary-foreground font-medium text-lg hover:bg-primary/90 transition-colors"
                >
                  Envoyer
                  <span class="w-12 h-12 rounded-full bg-primary-foreground text-primary flex items-center justify-center group-hover:scale-95 transition-transform">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
                  </span>
                </button>
              </div>
            </form>

            <!-- Calendly -->
            <div class="reveal mt-10 pt-8 border-t border-primary/10">
              <p class="text-primary/50 mb-4">Ou réservez directement un créneau</p>
              <a href="#" onclick="Calendly.initPopupWidget({url:'https://calendly.com/rdv-seo-save-your-web/30min'});return false;" class="inline-flex items-center gap-3 rounded-full border border-accent-warm/30 px-6 py-3 text-accent-warm font-medium hover:bg-accent-warm/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                Réserver un créneau
              </a>
            </div>
          </div>

          <!-- Right column: Map + Info -->
          <div class="reveal flex flex-col gap-8">
            <!-- Google Maps -->
            <div class="rounded-2xl overflow-hidden border border-primary/10 aspect-square lg:aspect-auto lg:h-[400px]">
              <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2628.5!2d2.1897!3d48.8256!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDjCsDQ5JzMyLjIiTiAywrAxMScyMi45IkU!5e0!3m2!1sfr!2sfr!4v1"
                width="100%" 
                height="100%" 
                style="border:0; border-radius: 16px;" 
                allowfullscreen 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade"
                title="Save Your Web — Ville-d'Avray"
              ></iframe>
            </div>

            <!-- Contact info -->
            <div class="bg-primary/5 border border-primary/10 rounded-2xl p-8 space-y-6">
              <h3 class="font-display text-xl font-medium">Informations de contact</h3>
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-xl bg-accent-warm/10 border border-accent-warm/20 flex items-center justify-center text-accent-warm flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                  </div>
                  <div>
                    <p class="text-sm text-primary/50">Email</p>
                    <a href="mailto:contact@saveyourweb.fr" class="text-primary hover:text-accent-warm transition-colors">contact@saveyourweb.fr</a>
                  </div>
                </div>

                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-xl bg-accent-warm/10 border border-accent-warm/20 flex items-center justify-center text-accent-warm flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <p class="text-sm text-primary/50">Adresse</p>
                    <p class="text-primary">Ville-d'Avray, France</p>
                  </div>
                </div>

                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 rounded-xl bg-accent-warm/10 border border-accent-warm/20 flex items-center justify-center text-accent-warm flex-shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  </div>
                  <div>
                    <p class="text-sm text-primary/50">Horaires</p>
                    <p class="text-primary">Lun-Ven, 9h-18h</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <StickyCTA />
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('form-success')!;
  const errorEl = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<span class="px-4">Envoi en cours...</span>';
    btn.disabled = true;

    try {
      const data = {
        name: (form.querySelector('#name') as HTMLInputElement).value,
        email: (form.querySelector('#email') as HTMLInputElement).value,
        website: (form.querySelector('#website') as HTMLInputElement).value,
        message: (form.querySelector('#message') as HTMLTextAreaElement).value,
      };

      const res = await fetch('https://saveyourweb-contact.pc-relange.workers.dev', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const result = await res.json();

      if (res.ok && result.success) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        errorEl.textContent = result.error || 'Une erreur est survenue.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Erreur de connexion. Veuillez réessayer.';
      errorEl.classList.remove('hidden');
    } finally {
      btn.innerHTML = originalText;
      btn.disabled = false;
    }
  });
</script>
