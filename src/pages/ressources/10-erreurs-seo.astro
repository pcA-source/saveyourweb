---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import StickyCTA from '../../components/StickyCTA.astro';
---

<Layout 
  title="10 erreurs SEO qui tuent votre trafic — Guide gratuit | Save Your Web"
  description="Téléchargez notre guide gratuit : 10 erreurs SEO courantes et comment les corriger. Boostez votre trafic organique dès aujourd'hui."
>
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="relative min-h-[80vh] flex items-center pt-32 pb-20 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-black via-black to-accent-warm/10"></div>
        <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
        <div class="absolute top-[20%] left-[10%] w-[500px] h-[500px] bg-accent-warm/8 rounded-full blur-[120px] animate-pulse-slow"></div>
        <div class="absolute bottom-[10%] right-[15%] w-[300px] h-[300px] bg-accent-warm/5 rounded-full blur-[100px]"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Left: Text -->
          <div>
            <div class="reveal inline-flex items-center gap-2 rounded-full border border-accent-warm/30 bg-accent-warm/10 backdrop-blur-md px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-accent-warm mb-8">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              Guide gratuit
            </div>

            <h1 class="reveal font-display text-4xl md:text-5xl lg:text-6xl leading-[1.05] font-medium tracking-tight text-primary mb-6">
              10 erreurs SEO<br />
              <span class="text-accent-warm">qui tuent votre trafic</span>
            </h1>

            <p class="reveal text-xl text-primary/70 mb-4 leading-relaxed">
              (et comment les corriger)
            </p>

            <ul class="reveal space-y-3 mb-10 text-primary/60">
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                Les 10 erreurs les plus fréquentes (et les plus coûteuses)
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                Une solution concrète pour chaque erreur
              </li>
              <li class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm flex-shrink-0"><polyline points="20 6 9 17 4 12"/></svg>
                Applicable immédiatement, quel que soit votre CMS
              </li>
            </ul>
          </div>

          <!-- Right: Form -->
          <div class="reveal">
            <div class="bg-primary/5 backdrop-blur-xl border border-primary/10 rounded-2xl p-8 md:p-10">
              <h2 class="font-display text-2xl font-medium mb-2">Téléchargez le guide</h2>
              <p class="text-primary/50 mb-8">Renseignez votre email pour recevoir le PDF gratuitement.</p>

              <!-- Success -->
              <div id="lead-success" class="hidden text-center py-8">
                <div class="text-5xl mb-4">📄</div>
                <h3 class="font-display text-2xl font-medium mb-3">Votre guide est prêt !</h3>
                <p class="text-primary/70 mb-6">Cliquez ci-dessous pour le télécharger.</p>
                <a href="/ressources/10-erreurs-seo-save-your-web.pdf" download class="cta-glow inline-flex items-center gap-3 rounded-full pl-8 pr-4 py-4 bg-accent-warm text-white font-medium text-lg hover:bg-accent-warm/90 transition-colors">
                  Télécharger le PDF
                  <span class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  </span>
                </a>
              </div>

              <div id="lead-error" class="hidden bg-red-500/10 border border-red-500/30 rounded-xl p-4 mb-6 text-red-400 text-sm"></div>

              <!-- Form -->
              <form id="lead-form" class="space-y-6">
                <div class="flex flex-col gap-2">
                  <label for="firstname" class="text-sm font-medium text-primary/60 uppercase tracking-wider">Prénom</label>
                  <input 
                    type="text" id="firstname" name="firstname" required
                    class="bg-black/50 border border-primary/20 rounded-xl px-4 py-3 text-primary placeholder:text-primary/30 focus:outline-none focus:border-accent-warm/50 transition-colors"
                    placeholder="Votre prénom"
                  />
                </div>

                <div class="flex flex-col gap-2">
                  <label for="lead-email" class="text-sm font-medium text-primary/60 uppercase tracking-wider">Email</label>
                  <input 
                    type="email" id="lead-email" name="email" required
                    class="bg-black/50 border border-primary/20 rounded-xl px-4 py-3 text-primary placeholder:text-primary/30 focus:outline-none focus:border-accent-warm/50 transition-colors"
                    placeholder="votre@email.com"
                  />
                </div>

                <button 
                  type="submit" 
                  class="cta-glow w-full flex items-center justify-center gap-3 rounded-full py-4 bg-accent-warm text-white font-medium text-lg hover:bg-accent-warm/90 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                  Recevoir le guide gratuit
                </button>

                <p class="text-xs text-primary/30 text-center">
                  Pas de spam. Vos données restent confidentielles.
                </p>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Preview: 10 erreurs list -->
    <section class="py-24 lg:py-32 bg-black relative">
      <div class="max-w-4xl mx-auto px-7 md:px-12 lg:px-20">
        <h2 class="reveal font-display text-3xl md:text-4xl font-medium tracking-tight mb-12 text-center">
          Ce que vous apprendrez
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {[
            "Ignorer l'intention de recherche",
            "Négliger le maillage interne",
            "Oublier les balises title et meta descriptions",
            "Ne pas optimiser pour mobile",
            "Ignorer la vitesse de chargement",
            "Dupliquer du contenu",
            "Négliger les données structurées",
            "Ne pas suivre ses positions",
            "Acheter des backlinks toxiques",
            "Ne pas avoir de stratégie de contenu",
          ].map((err, i) => (
            <div class="reveal flex items-start gap-4 p-4 rounded-xl border border-primary/10 hover:border-accent-warm/20 transition-colors">
              <span class="font-display text-2xl font-bold text-accent-warm/40 flex-shrink-0 w-8">{String(i + 1).padStart(2, '0')}</span>
              <span class="text-primary/70">{err}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <StickyCTA />
</Layout>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement;
  const successEl = document.getElementById('lead-success')!;
  const errorEl = document.getElementById('lead-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<span class="px-4">Envoi en cours...</span>';
    btn.disabled = true;

    try {
      const formData = new FormData();
      formData.append('name', (form.querySelector('#firstname') as HTMLInputElement).value);
      formData.append('email', (form.querySelector('#lead-email') as HTMLInputElement).value);
      formData.append('type', 'lead_magnet');
      formData.append('message', 'Demande de téléchargement : 10 erreurs SEO');

      const res = await fetch('https://saveyourweb-contact.pc-relange.workers.dev', {
        method: 'POST',
        body: formData,
      });

      const result = await res.json();

      if (res.ok && result.success) {
        form.classList.add('hidden');
        successEl.classList.remove('hidden');
      } else {
        errorEl.textContent = result.error || 'Une erreur est survenue.';
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = 'Erreur de connexion. Veuillez réessayer.';
      errorEl.classList.remove('hidden');
    } finally {
      btn.innerHTML = originalText;
      btn.disabled = false;
    }
  });
</script>
