---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import StickyCTA from '../../components/StickyCTA.astro';

const articles = [
  {
    slug: "ameliorer-referencement-naturel-2026",
    title: "Comment améliorer son référencement naturel en 2026 : le guide complet",
    description: "Toutes les techniques SEO qui fonctionnent en 2026 : audit technique, contenu, netlinking, Core Web Vitals. Guide actionnable pour PME et e-commerce.",
    date: "2026-03-01",
    readTime: "12 min de lecture",
    tag: "SEO",
  },
  {
    slug: "erreurs-google-ads-budget",
    title: "Google Ads : 7 erreurs qui brûlent votre budget publicitaire",
    description: "Les erreurs les plus fréquentes des PME sur Google Ads — et comment les éviter pour maximiser votre ROAS.",
    date: "2026-02-15",
    readTime: "8 min de lecture",
    tag: "Google Ads",
  },
  {
    slug: "seo-vs-sea-quelle-strategie",
    title: "SEO vs SEA : quelle stratégie choisir pour votre entreprise ?",
    description: "Comparatif objectif SEO vs SEA. Avantages, inconvénients, coûts, délais. Comment choisir la bonne stratégie d'acquisition.",
    date: "2026-02-01",
    readTime: "9 min de lecture",
    tag: "Stratégie",
  },
];
---

<Layout 
  title="Blog SEO & Google Ads | Conseils et guides | Save Your Web"
  description="Blog expert SEO & Google Ads : guides pratiques, études de cas et conseils actionnables pour améliorer votre référencement et vos campagnes publicitaires."
>
  <Navbar />
  <main>
    <!-- Hero -->
    <section class="relative pt-32 pb-16 overflow-hidden">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-br from-black via-black to-accent-warm/8"></div>
        <div class="absolute top-[20%] right-[20%] w-[300px] h-[300px] bg-accent-warm/6 rounded-full blur-[100px] animate-pulse-slow"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black/60"></div>
      </div>

      <div class="relative z-10 max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
        <div class="reveal inline-flex items-center gap-2 rounded-full border border-primary/20 bg-black/50 backdrop-blur-md px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-primary mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent-warm"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/></svg>
          Blog
        </div>
        <h1 class="reveal font-display text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight mb-6">
          Blog<span class="text-primary/60"> SEO & Ads</span>
        </h1>
        <p class="reveal text-xl text-primary/60 max-w-2xl">
          Guides pratiques, analyses et conseils actionnables pour votre référencement et vos campagnes publicitaires.
        </p>
      </div>
    </section>

    <!-- Articles Grid -->
    <section class="py-16 lg:py-24 bg-black">
      <div class="max-w-7xl mx-auto px-7 md:px-12 lg:px-20">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {articles.map((article) => (
            <a href={`/blog/${article.slug}/`} class="card-hover group bg-primary/5 border border-primary/10 rounded-2xl overflow-hidden block">
              <!-- Color bar -->
              <div class="h-1 bg-gradient-to-r from-accent-warm to-accent-warm/40"></div>
              
              <div class="p-8">
                <div class="flex items-center justify-between mb-4">
                  <span class="inline-flex items-center rounded-full bg-accent-warm/10 border border-accent-warm/20 px-3 py-1 text-xs font-medium uppercase tracking-widest text-accent-warm">
                    {article.tag}
                  </span>
                  <span class="text-xs text-primary/40">{article.readTime}</span>
                </div>

                <h2 class="font-display text-xl font-medium mb-4 group-hover:text-accent-warm transition-colors leading-snug">
                  {article.title}
                </h2>

                <p class="text-sm text-primary/50 leading-relaxed mb-6">
                  {article.description}
                </p>

                <div class="flex items-center justify-between">
                  <time class="text-xs text-primary/40" datetime={article.date}>
                    {new Date(article.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                  </time>
                  <span class="text-accent-warm text-sm font-medium group-hover:translate-x-1 transition-transform">
                    Lire →
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <StickyCTA />
</Layout>

<!-- Scroll reveal handled globally by Layout -->
