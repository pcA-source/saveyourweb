---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  readTime: string;
  author?: string;
  keyword?: string;
}

const { title, description, date, readTime, author = "Pierre-Charles Relange", keyword } = Astro.props;
---

<Layout title={`${title} | Blog Save Your Web`} description={description}>
  <Navbar />
  <main>
    <article class="pt-32 pb-20">
      <!-- Header -->
      <header class="max-w-3xl mx-auto px-7 md:px-12 mb-12">
        <div class="reveal inline-flex items-center gap-3 text-sm text-primary/50 mb-6">
          <a href="/blog/" class="hover:text-accent-warm transition-colors">Blog</a>
          <span>›</span>
          <time datetime={date}>{new Date(date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
          <span>·</span>
          <span>{readTime}</span>
        </div>

        <h1 class="reveal font-display text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight leading-[1.15] mb-6">
          {title}
        </h1>

        <div class="reveal flex items-center gap-4">
          <img src="/signature/photo-pc.png" alt={author} class="w-10 h-10 rounded-full object-cover border border-primary/10" />
          <div>
            <p class="text-sm font-medium text-primary">{author}</p>
            <p class="text-xs text-primary/50">Consultant SEO & SEA</p>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="max-w-3xl mx-auto px-7 md:px-12 prose-article">
        <slot />
      </div>

      <!-- CTA -->
      <div class="max-w-3xl mx-auto px-7 md:px-12 mt-16">
        <div class="reveal relative rounded-2xl overflow-hidden border border-primary/10 p-8 md:p-12">
          <div class="absolute inset-0 bg-gradient-to-br from-accent-warm/10 via-black to-accent-warm/5"></div>
          <div class="relative z-10">
            <h3 class="font-display text-2xl md:text-3xl font-medium mb-4">
              Besoin d'aide avec votre SEO ?
            </h3>
            <p class="text-primary/60 mb-6 max-w-lg">
              Demandez un audit gratuit de votre site — nous identifions les opportunités de croissance en moins de 48h.
            </p>
            <a href="/#contact" class="cta-glow inline-flex items-center gap-3 rounded-full pl-6 pr-3 py-3 bg-primary text-primary-foreground font-medium hover:bg-primary/90 transition-colors">
              Demander un Audit Gratuit
              <span class="w-8 h-8 rounded-full bg-primary-foreground text-primary flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </article>
  </main>
  <Footer />
  <StickyCTA />
</Layout>

<!-- Scroll reveal handled globally by Layout -->
