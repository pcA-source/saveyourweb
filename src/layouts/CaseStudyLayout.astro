---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  clientName: string;
  sector: string;
  period: string;
  mainMetric: string;
  mainMetricLabel: string;
  logo?: string;
  initials?: string;
  challenge: string;
  solution: string;
  tags: string[];
  results: { value: string; label: string }[];
  testimonial?: { quote: string; author: string };
}

const {
  title,
  description,
  clientName,
  sector,
  period,
  mainMetric,
  mainMetricLabel,
  logo,
  initials,
  challenge,
  solution,
  tags,
  results,
  testimonial,
} = Astro.props;
---

<Layout title={title} description={description}>
  <Navbar />
  <main class="pt-32 pb-24 bg-black min-h-screen">
    <!-- Breadcrumb -->
    <div class="max-w-5xl mx-auto px-7 md:px-12 lg:px-20 mb-12">
      <nav class="flex items-center gap-2 text-sm text-primary/40">
        <a href="/" class="hover:text-primary transition-colors">Accueil</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <a href="/etudes-de-cas/" class="hover:text-primary transition-colors">Études de cas</a>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-primary/60">{clientName}</span>
      </nav>
    </div>

    <!-- Hero -->
    <section class="max-w-5xl mx-auto px-7 md:px-12 lg:px-20 mb-20">
      <div class="animate-fade-in-up">
        <div class="flex items-center gap-5 mb-8">
          {logo ? (
            <img src={logo} alt={clientName} width="64" height="64" loading="lazy" decoding="async" class="w-16 h-16 rounded-2xl object-contain bg-white/10 p-2" />
          ) : (
            <div class="w-16 h-16 rounded-2xl bg-accent-warm/15 border border-accent-warm/30 flex items-center justify-center font-display font-bold text-accent-warm text-2xl">{initials}</div>
          )}
          <div>
            <h1 class="font-display text-3xl md:text-4xl font-medium tracking-tight text-primary">{clientName}</h1>
            <div class="flex items-center gap-3 mt-1">
              <span class="text-primary/50 text-sm">{sector}</span>
              <span class="text-primary/20">•</span>
              <span class="text-primary/50 text-sm">{period}</span>
            </div>
          </div>
        </div>

        <div class="bg-primary/5 border border-primary/10 rounded-2xl p-8 md:p-10">
          <span class="text-sm uppercase tracking-widest text-accent-warm font-medium">Résultat principal</span>
          <div class="mt-3">
            <span class="font-display text-5xl md:text-6xl lg:text-7xl font-medium tracking-tighter text-primary counter-value" data-target={mainMetric}>{mainMetric}</span>
            <span class="block text-lg text-primary/50 mt-2">{mainMetricLabel}</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Challenge -->
    <section class="max-w-5xl mx-auto px-7 md:px-12 lg:px-20 mb-20">
      <div class="reveal">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-10 rounded-xl bg-accent-warm/10 border border-accent-warm/20 flex items-center justify-center text-xl">🎯</div>
          <h2 class="font-display text-2xl md:text-3xl font-medium tracking-tight text-primary">Le Challenge</h2>
        </div>
        <div class="bg-primary/5 border border-primary/10 rounded-2xl p-8">
          <p class="text-primary/70 leading-relaxed text-lg">{challenge}</p>
        </div>
      </div>
    </section>

    <!-- Solution -->
    <section class="max-w-5xl mx-auto px-7 md:px-12 lg:px-20 mb-20">
      <div class="reveal">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-10 rounded-xl bg-accent-warm/10 border border-accent-warm/20 flex items-center justify-center text-xl">💡</div>
          <h2 class="font-display text-2xl md:text-3xl font-medium tracking-tight text-primary">Notre Solution</h2>
        </div>
        <div class="bg-primary/5 border border-primary/10 rounded-2xl p-8">
          <p class="text-primary/70 leading-relaxed text-lg mb-6">{solution}</p>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <span class="inline-flex items-center rounded-full bg-accent-warm/10 border border-accent-warm/20 px-4 py-1.5 text-xs font-medium uppercase tracking-widest text-accent-warm">
                {tag}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Results -->
    <section class="max-w-5xl mx-auto px-7 md:px-12 lg:px-20 mb-20">
      <div class="reveal">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-10 rounded-xl bg-accent-warm/10 border border-accent-warm/20 flex items-center justify-center text-xl">📊</div>
          <h2 class="font-display text-2xl md:text-3xl font-medium tracking-tight text-primary">Les Résultats</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {results.map((r) => (
            <div class="card-hover bg-primary/5 border border-primary/10 rounded-2xl p-6 text-center">
              <span class="font-display text-3xl md:text-4xl font-medium tracking-tighter text-primary counter-value" data-target={r.value}>{r.value}</span>
              <span class="block text-sm text-primary/50 mt-2">{r.label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    {testimonial && (
      <section class="max-w-5xl mx-auto px-7 md:px-12 lg:px-20 mb-20">
        <div class="reveal">
          <div class="bg-primary/5 border border-accent-warm/20 rounded-2xl p-8 md:p-10 relative">
            <div class="absolute top-6 left-8 text-accent-warm/20 font-display text-7xl leading-none">"</div>
            <blockquote class="relative z-10 pt-8">
              <p class="text-primary/80 text-lg md:text-xl leading-relaxed italic">{testimonial.quote}</p>
              <footer class="mt-6 text-sm text-accent-warm font-medium">— {testimonial.author}</footer>
            </blockquote>
          </div>
        </div>
      </section>
    )}

    <!-- CTA -->
    <section class="max-w-5xl mx-auto px-7 md:px-12 lg:px-20">
      <div class="reveal">
        <div class="relative rounded-[2rem] overflow-hidden border border-primary/10">
          <div class="absolute inset-0 z-0">
            <div class="absolute inset-0 bg-gradient-to-br from-accent-warm/15 via-black to-accent-warm/5"></div>
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_left,_hsl(25_100%_50%/0.1)_0%,_transparent_50%)]"></div>
          </div>
          <div class="relative z-10 p-8 md:p-16 text-center">
            <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-medium tracking-tight mb-4">
              Votre entreprise mérite<br />
              <span class="text-primary/70">ces résultats.</span>
            </h2>
            <p class="text-lg text-primary/60 mb-8 max-w-xl mx-auto">
              Demandez votre audit gratuit et découvrez le potentiel SEO de votre site.
            </p>
            <a href="#" onclick="Calendly.initPopupWidget({url:'https://calendly.com/rdv-seo-save-your-web/30min'});return false;" class="cta-glow inline-flex items-center gap-3 rounded-full pl-8 pr-3 py-3 bg-primary text-primary-foreground font-medium text-lg hover:bg-primary/90 transition-colors">
              Demander mon audit gratuit
              <span class="w-12 h-12 rounded-full bg-primary-foreground text-primary flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <slot />
  </main>
  <Footer />
</Layout>
