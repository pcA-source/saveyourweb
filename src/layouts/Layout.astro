---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

import CookieBanner from '../components/CookieBanner.astro';

const { 
  title, 
  description = "Save Your Web — Agence SEO & SEA à Paris. Référencement naturel et Google Ads pour PME, e-commerce et startups. Dominez Google avec une stratégie sur-mesure.",
  ogImage = "/og-image.jpg",
  canonical
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;

// BreadcrumbList schema
const pathSegments = Astro.url.pathname.replace(/\/$/, '').split('/').filter(Boolean);
const breadcrumbLabelMap: Record<string, string> = {
  'services': 'Services',
  'seo': 'SEO',
  'sea': 'SEA',
  'etudes-de-cas': 'Études de cas',
  'blog': 'Blog',
  'a-propos': 'À propos',
  'contact': 'Contact',
  'tarifs': 'Tarifs',
  'ressources': 'Ressources',
  'mentions-legales': 'Mentions légales',
  'politique-de-confidentialite': 'Confidentialité',
};

let breadcrumbSchema = '';
if (pathSegments.length > 0) {
  const items = [{ name: 'Accueil', url: 'https://saveyourweb.fr/' }];
  let accum = '';
  for (const seg of pathSegments) {
    accum += '/' + seg;
    items.push({
      name: breadcrumbLabelMap[seg] || seg.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()),
      url: 'https://saveyourweb.fr' + accum + '/'
    });
  }
  breadcrumbSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": items.map((item, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": item.name,
      "item": item.url
    }))
  });
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Save Your Web" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    
    <!-- Fonts (self-hosted for performance) -->
    <link rel="preload" href="/fonts/Inter-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/SpaceGrotesk-Latin.woff2" as="font" type="font/woff2" crossorigin />
    
    <!-- Calendly widget -->
    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" />
    <script src="https://assets.calendly.com/assets/external/widget.js" async is:inline></script>
    
    <!-- Schema.org — LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "ProfessionalService"],
      "name": "Save Your Web",
      "description": "Agence SEO & SEA spécialisée en référencement naturel et Google Ads pour PME, e-commerce et startups.",
      "url": "https://saveyourweb.fr",
      "email": "contact@saveyourweb.fr",
      "founder": {
        "@type": "Person",
        "name": "Pierre-Charles Relange"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "17 chemin des Vallières",
        "addressLocality": "Ville-d'Avray",
        "postalCode": "92410",
        "addressCountry": "FR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 48.8256,
        "longitude": 2.1897
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "contact@saveyourweb.fr",
        "contactType": "customer service",
        "availableLanguage": ["French", "English"]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5",
        "bestRating": "5",
        "worstRating": "1",
        "ratingCount": "12"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
        "opens": "09:00",
        "closes": "18:00"
      },
      "areaServed": "FR",
      "serviceType": ["SEO", "SEA", "Référencement naturel", "Google Ads", "Meta Ads"],
      "priceRange": "€€€",
      "sameAs": []
    })} />

    <!-- Schema.org — BreadcrumbList -->
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={breadcrumbSchema} />
    )}
  </head>
  <body class="min-h-screen bg-black text-primary font-sans antialiased">
    <script is:inline>
      if(window.location.hostname.endsWith('.pages.dev')||window.location.hostname==='www.saveyourweb.fr'){
        window.location.replace('https://saveyourweb.fr'+window.location.pathname+window.location.search);
      }
    </script>
    <slot />
    
    <style is:global>
      @import '../styles/global.css';
    </style>

    <CookieBanner />

    <!-- Global scroll reveal & counter animations -->
    <script is:inline>
      // Scroll reveal with stagger
      (function() {
        var ro = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry, i) {
            if (entry.isIntersecting) {
              setTimeout(function() { entry.target.classList.add('visible'); }, i * 100);
              ro.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });
        document.querySelectorAll('.reveal').forEach(function(el) { ro.observe(el); });

        // Counter animation
        function animateCounter(el) {
          var text = el.getAttribute('data-target') || el.textContent || '';
          var match = text.match(/([+-]?)(\d+(?:[.,]\d+)?)/);
          if (!match) return;
          var prefix = text.replace(/[\d.,]+.*/, '');
          var suffix = text.replace(/.*[\d.,]+/, '');
          var target = parseFloat(match[2].replace(',', '.'));
          var duration = 2000;
          var start = performance.now();
          function step(now) {
            var progress = Math.min((now - start) / duration, 1);
            var eased = 1 - Math.pow(1 - progress, 3);
            var current = Math.round(target * eased);
            el.textContent = prefix + current + suffix;
            if (progress < 1) requestAnimationFrame(step);
            else el.textContent = text;
          }
          requestAnimationFrame(step);
        }
        var co = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              animateCounter(entry.target);
              co.unobserve(entry.target);
            }
          });
        }, { threshold: 0.5 });
        document.querySelectorAll('.counter-value').forEach(function(el) { co.observe(el); });
      })();
    </script>
  </body>
</html>
