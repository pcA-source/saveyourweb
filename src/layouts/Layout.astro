---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
}

const { 
  title, 
  description = "Save Your Web — Agence SEO & SEA à Paris. Référencement naturel et Google Ads pour PME, e-commerce et startups. Dominez Google avec une stratégie sur-mesure.",
  ogImage = "/og-image.jpg",
  canonical
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Save Your Web" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "ProfessionalService"],
      "name": "Save Your Web",
      "description": "Agence SEO & SEA spécialisée en référencement naturel et Google Ads pour PME, e-commerce et startups.",
      "url": "https://saveyourweb.fr",
      "email": "contact@saveyourweb.fr",
      "founder": {
        "@type": "Person",
        "name": "Pierre-Charles Relange"
      },
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "FR"
      },
      "areaServed": "FR",
      "serviceType": ["SEO", "SEA", "Référencement naturel", "Google Ads", "Meta Ads"],
      "priceRange": "€€€",
      "sameAs": []
    })} />
  </head>
  <body class="min-h-screen bg-black text-primary font-sans antialiased">
    <slot />
    
    <style is:global>
      @import '../styles/global.css';
    </style>
  </body>
</html>
